# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to git.

# Password staff must enter to access the chatbot
APP_PASSWORD=LeGreenNumber1

# Your Gemini API key (kept server-side only)
GEMINI_API_KEY=your-real-gemini-api-key-here

# Gemini model to use (optional, defaults to gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# Random secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Set to "production" when deploying behind HTTPS
NODE_ENV=production
